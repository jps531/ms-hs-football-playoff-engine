# --- Environment ---
ENVIRONMENT=local
NETWORK=mshsfootball-${ENVIRONMENT}
COMPOSE_PROFILES=local-db

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mshsfootball
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_RANDOM_PASSWORD

# --- API ---
API_PORT=8000
FRONTEND_ORIGIN=https://yourdomain.com

# --- Prefect ---
PREFECT_API_URL=http://prefect-server:4200/api
PREFECT_LOGGING_LEVEL=INFO
PREFECT_PORT=4200
PYTHONPATH=/opt/prefect/flows/pipelines

# --- Nginx ---
NGINX_PORT=80

# --- Versions ---
PREFECT_VERSION=2.17.1
PYTHON_VERSION=3.11
POSTGRES_VERSION=17
NGINX_VERSION=1.27-alpine

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BASE_URL=https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload

# --- Auth0 ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=